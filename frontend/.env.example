# Copie este arquivo para .env.production e preencha os valores.
# No Vercel: configure as variáveis abaixo no dashboard do projeto (Settings > Environment Variables).

# URL da API no Render (sem /api no final)
VITE_API_URL=https://financeflow-api-xxxx.onrender.com

# API Key — deve bater com API_KEY definida no Render
VITE_API_KEY=troque-por-uma-senha-forte
