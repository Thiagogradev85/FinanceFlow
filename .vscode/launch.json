{
  "version": "0.2.0",
  "configurations": [
    {
      // Config PADRÃO do F5: sobe Docker, builda, inicia o Vite (que abre o navegador)
      // e roda a API .NET com o debugger anexado. Back + Front num único F5.
      "name": "🚀 FinanceFlow (back + front)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "start-stack",
      "program": "${workspaceFolder}/src/FinanceFlow.Api/bin/Debug/net10.0/FinanceFlow.Api.dll",
      "cwd": "${workspaceFolder}/src/FinanceFlow.Api",
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5080"
      }
    },
    {
      // Só a API (sem frontend), útil pra depurar o back isolado.
      "name": "API somente (.NET)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/FinanceFlow.Api/bin/Debug/net10.0/FinanceFlow.Api.dll",
      "cwd": "${workspaceFolder}/src/FinanceFlow.Api",
      "console": "integratedTerminal",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5080"
      }
    }
  ]
}
